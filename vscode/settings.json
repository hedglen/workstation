{
  // =============================================================================
  //   Theme & Appearance
  // =============================================================================
  "workbench.colorTheme": "Oled Neon Theme Black",
  "workbench.iconTheme": "material-icon-theme",
  "workbench.tree.indent": 16,
  "workbench.editor.enablePreview": false,
  "workbench.editor.tabSizing": "shrink",

  // =============================================================================
  //   Editor — Core
  // =============================================================================
  "editor.fontFamily": "'Cascadia Code', 'Fira Code', Consolas, monospace",
  "editor.fontLigatures": true,
  "editor.fontSize": 14,
  "editor.lineHeight": 1.6,
  "editor.tabSize": 4,
  "editor.insertSpaces": true,
  "editor.wordWrap": "off",
  "editor.rulers": [100],

  // =============================================================================
  //   Editor — Visual Aids
  // =============================================================================
  "editor.minimap.enabled": false,
  "editor.renderWhitespace": "boundary",
  "editor.bracketPairColorization.enabled": true,
  "editor.guides.bracketPairs": true,
  "editor.stickyScroll.enabled": true,
  "editor.renderLineHighlight": "all",

  // =============================================================================
  //   Editor — Animation & Feel
  // =============================================================================
  "editor.cursorBlinking": "smooth",
  "editor.cursorSmoothCaretAnimation": "on",
  "editor.smoothScrolling": true,

  // =============================================================================
  //   Editor — Suggestions & Completions
  // =============================================================================
  "editor.inlineSuggest.enabled": true,
  "editor.suggest.preview": true,
  "editor.suggest.insertMode": "replace",
  "editor.acceptSuggestionOnCommitCharacter": false,

  // =============================================================================
  //   Editor — Save Behavior
  // =============================================================================
  "editor.formatOnSave": true,
  "files.trimTrailingWhitespace": true,
  "files.insertFinalNewline": true,
  "files.autoSave": "onFocusChange",

  // =============================================================================
  //   Terminal
  // =============================================================================
  "terminal.integrated.fontFamily": "'CaskaydiaCove Nerd Font', 'Cascadia Code', Consolas",
  "terminal.integrated.fontSize": 13,
  "terminal.integrated.defaultProfile.windows": "PowerShell",
  "terminal.integrated.cursorStyle": "line",
  "terminal.integrated.cursorBlinking": true,
  "terminal.integrated.smoothScrolling": true,
  "terminal.integrated.scrollback": 10000,
  "terminal.integrated.scrollbar.verticalScrollbarSize": 12,
  "terminal.integrated.background": "#0E0E0E",
  "terminal.integrated.foreground": "#E4E4E4",
  "terminal.integrated.ansiBlack": "#252525",
  "terminal.integrated.ansiRed": "#FF6B8A",
  "terminal.integrated.ansiGreen": "#00E8B5",
  "terminal.integrated.ansiYellow": "#FFD447",
  "terminal.integrated.ansiBlue": "#64B5FF",
  "terminal.integrated.ansiMagenta": "#E954FF",
  "terminal.integrated.ansiCyan": "#00E8FF",
  "terminal.integrated.ansiWhite": "#C8C8D0",
  "terminal.integrated.ansiBrightBlack": "#4A4A55",
  "terminal.integrated.ansiBrightRed": "#FF99AA",
  "terminal.integrated.ansiBrightGreen": "#5CFFB8",
  "terminal.integrated.ansiBrightYellow": "#FFE566",
  "terminal.integrated.ansiBrightBlue": "#A8D4FF",
  "terminal.integrated.ansiBrightMagenta": "#F4A4FF",
  "terminal.integrated.ansiBrightCyan": "#66F9FF",
  "terminal.integrated.ansiBrightWhite": "#FFFFFF",

  "workbench.colorCustomizations": {
    "terminal.background": "#0E0E0E",
    "terminal.foreground": "#E4E4E4",
    "terminalCursor.foreground": "#FF66EE",
    "terminal.selectionBackground": "#3D2560",
    "terminal.ansiBlack": "#252525",
    "terminal.ansiRed": "#FF6B8A",
    "terminal.ansiGreen": "#00E8B5",
    "terminal.ansiYellow": "#FFD447",
    "terminal.ansiBlue": "#64B5FF",
    "terminal.ansiMagenta": "#E954FF",
    "terminal.ansiCyan": "#00E8FF",
    "terminal.ansiWhite": "#C8C8D0",
    "terminal.ansiBrightBlack": "#4A4A55",
    "terminal.ansiBrightRed": "#FF99AA",
    "terminal.ansiBrightGreen": "#5CFFB8",
    "terminal.ansiBrightYellow": "#FFE566",
    "terminal.ansiBrightBlue": "#A8D4FF",
    "terminal.ansiBrightMagenta": "#F4A4FF",
    "terminal.ansiBrightCyan": "#66F9FF",
    "terminal.ansiBrightWhite": "#FFFFFF",
  },

  // =============================================================================
  //   Explorer
  // =============================================================================
  "explorer.confirmDelete": false,
  "explorer.confirmDragAndDrop": false,
  "explorer.compactFolders": false,
  "search.exclude": {
    "**/node_modules": true,
    "**/.git": true,
    "**/dist": true,
    "**/__pycache__": true,
  },

  // =============================================================================
  //   Git
  // =============================================================================
  "git.autofetch": true,
  "git.confirmSync": false,
  "git.enableSmartCommit": true,
  "diffEditor.ignoreTrimWhitespace": false,

  // =============================================================================
  //   Extensions — Claude Code
  // =============================================================================
  "security.workspace.trust.untrustedFiles": "open",
  "claudeCode.preferredLocation": "panel",

  // =============================================================================
  //   Extensions — GitLens
  // =============================================================================
  "gitlens.ai.model": "vscode",
  "gitlens.ai.vscode.model": "copilot:gpt-4o-mini",
  "gitlens.codeLens.enabled": false,

  // =============================================================================
  //   Extensions — Copilot
  // =============================================================================
  "github.copilot.enable": {
    "*": true,
  },

  // =============================================================================
  //   Language — PowerShell
  // =============================================================================
  "[powershell]": {
    "editor.defaultFormatter": "ms-vscode.powershell",
    "editor.tabSize": 4,
    "editor.formatOnSave": true,
  },
  "powershell.integratedConsole.showOnStartup": false,
  "powershell.scriptAnalysis.enable": true,

  // =============================================================================
  //   Language — Python
  // =============================================================================
  "[python]": {
    "editor.defaultFormatter": "ms-python.black-formatter",
    "editor.tabSize": 4,
    "editor.formatOnSave": true,
  },
  "python.languageServer": "None",
  "python.analysis.typeCheckingMode": "basic",
  "python.analysis.autoImportCompletions": true,

  // =============================================================================
  //   Language — AutoHotkey
  // =============================================================================
  "AutoHotkey2.InterpreterPath": "C:\\Program Files\\AutoHotkey\\v2\\AutoHotkey64.exe",

  // =============================================================================
  //   Language — Lua
  // =============================================================================
  "[lua]": {
    "editor.tabSize": 4,
    "editor.defaultFormatter": "sumneko.lua",
  },
  "Lua.diagnostics.globals": ["mp", "mp_event_loop"],
  "Lua.workspace.library": [],

  // =============================================================================
  //   Language — JSON / YAML
  // =============================================================================
  "[json]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
  },
  "[jsonc]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
  },
  "[yaml]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
  },

  // =============================================================================
  //   Language — Markdown
  // =============================================================================
  "[markdown]": {
    "editor.wordWrap": "on",
    "editor.quickSuggestions": {
      "other": false,
    },
  },
  "workbench.startupEditor": "none",
  "terminal.integrated.enableMultiLinePasteWarning": "never",
  "chat.tools.terminal.autoApprove": true,
  "workbench.scrollbar.verticalScrollbarSize": 14,
  "editor.scrollbar.verticalScrollbarSize": 14,
  "cSpell.userWords": ["Aethra", "autohotkey", "hedglen", "shinchiro", "slnx"],
  "git.openRepositoryInParentFolders": "never",
  "cursorpyright.analysis.autoImportCompletions": true,
  "cursorpyright.analysis.typeCheckingMode": "basic",
  "vsicons.dontShowNewVersionMessage": true,
}