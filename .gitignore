# Backups created by install.ps1
*.backup

# Secrets — never commit these
.env
*.key
*.pem
id_rsa
id_ed25519

# Windows junk
Thumbs.db
desktop.ini
$RECYCLE.BIN/

# Editor
.vscode/
*.swp

# Python cache — never commit, anywhere in the repo
__pycache__/
*.pyc

# Bundled Python projects (local venv + secrets — never commit)
projects/**/.venv/
projects/**/cookies.txt

# mpv-config — see mpv-config/.gitignore for shader cache, watch_later, etc.

# Portable tools — binaries only, not tracked
tools/

# Personal notes — never push to the public remote
notes/personal/
