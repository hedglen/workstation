{
  // ===========================================================================
  //  Scoop CLI manifest — portable command-line tools.
  //  Parsed by install.ps1 and maintenance/update.ps1 (PowerShell ConvertFrom-Json,
  //  which tolerates these // comments).
  //  Buckets: main, except lazygit (extras) — install.ps1 adds the extras bucket.
  //  Per-package notes: apps/scoop-packages.md
  // ===========================================================================
  "packages": [

    // ── Search & navigation ──────────────────────────────────────────────────
    "fd",           // find files by name
    "fzf",          // fuzzy picker
    "ripgrep",      // search file contents (rg)
    "zoxide",       // smart cd (z / zi)
    "scoop-search", // search scoop manifests

    // ── View, edit, diff ─────────────────────────────────────────────────────
    "bat",          // cat with syntax highlighting
    "glow",         // markdown in the terminal
    "delta",        // rich git diffs
    "sd",           // simple find-and-replace
    "less",         // plain pager (referenced by the coding-tab cheat sheet)

    // ── Git & GitHub ─────────────────────────────────────────────────────────
    "gh",           // GitHub CLI
    "git-lfs",      // large file storage
    "lazygit",      // git TUI (extras bucket)

    // ── Data wrangling ───────────────────────────────────────────────────────
    "jq",           // JSON
    "yq",           // YAML/XML/CSV

    // ── System & files ───────────────────────────────────────────────────────
    "dust",         // disk usage tree
    "duf",          // better df - disk usage
    "exiftool",     // media metadata read/write (pairs with media-organizer / yt-dlp)
    "eza",          // modern ls
    "fastfetch",    // system info banner
    "gsudo",        // sudo for Windows
    "hyperfine",    // command benchmarking
    "openssh",      // SSH client
    "rclone",       // cloud storage sync
    "tree",         // directory tree listing
    "wget",         // downloads in scripts

    // ── Docs & task running ──────────────────────────────────────────────────
    "pandoc",       // document conversion
    "just",         // command runner
    "tealdeer"      // tldr pages
  ]
}
